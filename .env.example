# Microsoft OAuth app credentials
# Register an app at https://portal.azure.com → App registrations
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
TENANT_ID=consumers

# HTTP server port (default: 3001)
PORT=3001

# Public URL of your server — used in the dashboard quick-add commands and OAuth redirect
# For local dev:     http://localhost:3001
# For self-hosted:   https://todo-mcp.yourdomain.com
PUBLIC_URL=http://localhost:3001

# OAuth callback URI — must match exactly what's registered in Azure App Registration
# Defaults to PUBLIC_URL/callback if not set
# For local dev:     http://localhost:3001/callback
# For self-hosted:   https://todo-mcp.yourdomain.com/callback
REDIRECT_URI=http://localhost:3001/callback

# API key to protect the /mcp endpoint
# Generate with: openssl rand -hex 32
MCP_API_KEY=your_secret_api_key_here

# Credentials to protect the dashboard (/, /auth, /callback) with HTTP basic auth
# Strongly recommended — without it anyone who knows your URL can trigger OAuth
# DASHBOARD_USERNAME defaults to "admin" if not set
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_dashboard_password_here

# Optional: custom path for the SQLite list registry database (default: ./lists.db)
# LIST_DB_PATH=/data/lists.db

# Optional: custom path for the tokens file (default: ./tokens.json)
# MSTODO_TOKEN_FILE=/data/tokens.json
